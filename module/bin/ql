#!/system/bin/sh

set -u

MODDIR="$(cd "${0%/*}/.." && pwd)"
STATE_DIR="${QL_STATE_DIR:-/data/adb/qinglong}"
ROOTFS="$STATE_DIR/rootfs"
DATA_DIR="$STATE_DIR/data"
LOG_DIR="$STATE_DIR/logs"
PID_FILE="$STATE_DIR/qinglong.pid"
LOCK_DIR="$STATE_DIR/.install.lock"
CONFIG_FILE="$STATE_DIR/config.env"
DEFAULT_CONFIG="$MODDIR/config.env"

log() {
  echo "[qinglong-ksu] $*"
}

config_init() {
  mkdir -p "$STATE_DIR"
  if [ ! -f "$CONFIG_FILE" ]; then
    cp "$DEFAULT_CONFIG" "$CONFIG_FILE"
    chmod 0600 "$CONFIG_FILE"
    return
  fi
  while IFS= read -r ci_line; do
    ci_key="${ci_line%%=*}"
    grep -q "^${ci_key}=" "$CONFIG_FILE" || echo "$ci_line" >>"$CONFIG_FILE"
  done <"$DEFAULT_CONFIG"
  chmod 0600 "$CONFIG_FILE"
}

config_get() {
  config_init
  cg_key="$1"
  is_config_key "$cg_key" || return 1
  sed -n "s/^${cg_key}=//p" "$CONFIG_FILE" | tail -n 1
}

is_config_key() {
  case "$1" in
    QL_PORT|TZ|DNS|BOOT_DELAY|AUTO_START) return 0 ;;
    *) return 1 ;;
  esac
}

validate_config() {
  vc_key="$1"
  vc_value="$2"
  case "$vc_key" in
    QL_PORT)
      case "$vc_value" in *[!0-9]*|"") return 1 ;; esac
      [ "$vc_value" -ge 1 ] && [ "$vc_value" -le 65535 ]
      ;;
    BOOT_DELAY)
      case "$vc_value" in *[!0-9]*|"") return 1 ;; esac
      [ "$vc_value" -ge 0 ] && [ "$vc_value" -le 600 ]
      ;;
    AUTO_START)
      [ "$vc_value" = "0" ] || [ "$vc_value" = "1" ]
      ;;
    TZ)
      case "$vc_value" in *[!A-Za-z0-9_+./-]*|"") return 1 ;; esac
      ;;
    DNS)
      case "$vc_value" in *[!A-Fa-f0-9:.,]*|"") return 1 ;; esac
      ;;
    *) return 1 ;;
  esac
}

config_set() {
  cs_key="$1"
  cs_value="$2"
  if ! validate_config "$cs_key" "$cs_value"; then
    log "Invalid value for $cs_key"
    return 1
  fi
  config_init
  cs_tmp="$CONFIG_FILE.tmp"
  grep -v "^${cs_key}=" "$CONFIG_FILE" >"$cs_tmp" || true
  printf '%s=%s\n' "$cs_key" "$cs_value" >>"$cs_tmp"
  chmod 0600 "$cs_tmp"
  mv "$cs_tmp" "$CONFIG_FILE"
  log "$cs_key updated"
}

config_list() {
  config_init
  cat "$CONFIG_FILE"
}

load_config() {
  QL_PORT="$(config_get QL_PORT)"
  TZ="$(config_get TZ)"
  DNS="$(config_get DNS)"
  BOOT_DELAY="$(config_get BOOT_DELAY)"
  AUTO_START="$(config_get AUTO_START)"
  export QL_PORT TZ DNS BOOT_DELAY AUTO_START
}

sha256_file() {
  if command -v sha256sum >/dev/null 2>&1; then
    sha256sum "$1" | awk '{print $1}'
  else
    toybox sha256sum "$1" | awk '{print $1}'
  fi
}

extract_runtime() {
  er_archive="$1"
  er_target="$2"
  if [ -x /data/adb/ksu/bin/busybox ]; then
    /data/adb/ksu/bin/busybox gzip -dc "$er_archive" |
      /data/adb/ksu/bin/busybox tar -xpf - -C "$er_target"
  elif [ -x /data/adb/magisk/busybox ]; then
    /data/adb/magisk/busybox gzip -dc "$er_archive" |
      /data/adb/magisk/busybox tar -xpf - -C "$er_target"
  else
    gzip -dc "$er_archive" | tar -xpf - -C "$er_target"
  fi
}

install_runtime() {
  [ -x "$ROOTFS/usr/local/bin/qinglong-container-entrypoint" ] && return 0

  if ! mkdir "$LOCK_DIR" 2>/dev/null; then
    log "Another runtime installation is in progress"
    return 1
  fi
  trap 'rm -rf "$LOCK_DIR"' EXIT INT TERM

  mkdir -p "$STATE_DIR" "$DATA_DIR" "$LOG_DIR"
  archive="$MODDIR/runtime.tar.gz"
  expected="$(cat "$MODDIR/runtime.sha256" 2>/dev/null)"
  if [ ! -s "$archive" ] || [ -z "$expected" ]; then
    log "Embedded runtime is missing or incomplete; reinstall the module"
    return 1
  fi
  actual="$(sha256_file "$archive")"
  if [ "$expected" != "$actual" ]; then
    log "Runtime checksum mismatch"
    return 1
  fi

  rm -rf "$ROOTFS.new"
  mkdir -p "$ROOTFS.new"
  if ! extract_runtime "$archive" "$ROOTFS.new"; then
    log "Runtime extraction failed; inspect $LOG_DIR/service.log"
    rm -rf "$ROOTFS.new"
    return 1
  fi
  if [ ! -x "$ROOTFS.new/usr/local/bin/qinglong-container-entrypoint" ]; then
    log "Runtime extraction was incomplete"
    rm -rf "$ROOTFS.new"
    return 1
  fi
  rm -rf "$ROOTFS"
  mv "$ROOTFS.new" "$ROOTFS"
  rm -f "$archive"
  log "Runtime installed"
}

is_mounted() {
  grep -q " $1 " /proc/mounts 2>/dev/null
}

bind_mount() {
  source="$1"
  target="$2"
  mkdir -p "$target"
  is_mounted "$target" || mount -o bind "$source" "$target"
}

mount_runtime() {
  mkdir -p "$DATA_DIR" "$ROOTFS/ql/data" "$ROOTFS/proc" "$ROOTFS/sys" "$ROOTFS/dev"
  bind_mount "$DATA_DIR" "$ROOTFS/ql/data"
  bind_mount /proc "$ROOTFS/proc"
  bind_mount /sys "$ROOTFS/sys"
  bind_mount /dev "$ROOTFS/dev"
  [ -e "$ROOTFS/dev/pts" ] && bind_mount /dev/pts "$ROOTFS/dev/pts"
  load_config
  : >"$ROOTFS/etc/resolv.conf"
  old_ifs="$IFS"
  IFS=,
  for server in $DNS; do
    printf 'nameserver %s\n' "$server" >>"$ROOTFS/etc/resolv.conf"
  done
  IFS="$old_ifs"
}

unmount_runtime() {
  for path in dev/pts dev sys proc ql/data; do
    is_mounted "$ROOTFS/$path" && umount -l "$ROOTFS/$path" 2>/dev/null
  done
}

is_running() {
  [ -s "$PID_FILE" ] && kill -0 "$(cat "$PID_FILE")" 2>/dev/null
}

start_service() {
  if is_running; then
    log "QingLong is already running (PID $(cat "$PID_FILE"))"
    return 0
  fi
  install_runtime || return 1
  mount_runtime || return 1
  load_config

  log "Starting QingLong on port $QL_PORT..."
  (
    export QlPort="$QL_PORT" TZ
    chroot "$ROOTFS" /usr/local/bin/qinglong-container-entrypoint
  ) >>"$LOG_DIR/qinglong.log" 2>&1 &
  pid=$!
  echo "$pid" >"$PID_FILE"
  sleep 3
  if ! kill -0 "$pid" 2>/dev/null; then
    log "QingLong exited during startup; inspect $LOG_DIR/qinglong.log"
    rm -f "$PID_FILE"
    return 1
  fi
  log "Started (PID $pid): http://127.0.0.1:$QL_PORT"
}

stop_service() {
  if is_running; then
    pid="$(cat "$PID_FILE")"
    log "Stopping QingLong (PID $pid)..."
    kill "$pid" 2>/dev/null
    tries=0
    while kill -0 "$pid" 2>/dev/null && [ "$tries" -lt 15 ]; do
      sleep 1
      tries=$((tries + 1))
    done
    kill -9 "$pid" 2>/dev/null || true
  fi
  rm -f "$PID_FILE"
  unmount_runtime
  log "Stopped"
}

status_service() {
  if is_running; then
    log "Running (PID $(cat "$PID_FILE"))"
    load_config
    log "Panel: http://127.0.0.1:$QL_PORT"
  elif [ -d "$ROOTFS" ]; then
    log "Installed but stopped"
  else
    log "Runtime not installed yet"
  fi
}

doctor() {
  config_init
  echo "state_dir=$STATE_DIR"
  echo "config_file=$CONFIG_FILE"
  echo "config_readable=$([ -r "$CONFIG_FILE" ] && echo yes || echo no)"
  echo "runtime_archive=$([ -s "$MODDIR/runtime.tar.gz" ] && echo present || echo absent)"
  echo "rootfs=$([ -x "$ROOTFS/usr/local/bin/qinglong-container-entrypoint" ] && echo installed || echo missing)"
  echo "running=$(is_running && echo yes || echo no)"
}

module_version() {
  sed -n 's/^version=//p' "$MODDIR/module.prop" | head -n 1
}

case "${1:-}" in
  start) start_service ;;
  stop) stop_service ;;
  restart) stop_service; start_service ;;
  status) status_service ;;
  install) install_runtime ;;
  logs) tail -n "${2:-100}" "$LOG_DIR/qinglong.log" ;;
  doctor) doctor ;;
  version) module_version ;;
  config)
    case "${2:-}" in
      init) config_init ;;
      get)
        [ -n "${3:-}" ] || exit 2
        config_get "$3"
        ;;
      set)
        [ -n "${3:-}" ] || exit 2
        if [ "${4:-}" = "-" ]; then
          value="$(cat)"
        else
          value="${4:-}"
        fi
        config_set "$3" "$value"
        ;;
      list) config_list ;;
      *) echo "Usage: ql config {init|get KEY|set KEY VALUE|list}"; exit 2 ;;
    esac
    ;;
  shell)
    install_runtime
    mount_runtime
    exec chroot "$ROOTFS" /bin/bash
    ;;
  *)
    echo "Usage: ql {install|start|stop|restart|status|logs [lines]|doctor|version|shell|config ...}"
    exit 2
    ;;
esac
