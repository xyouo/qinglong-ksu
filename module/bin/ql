#!/system/bin/sh

set -u

MODDIR="$(cd "${0%/*}/.." && pwd)"
STATE_DIR="${QL_STATE_DIR:-/data/adb/qinglong}"
ROOTFS="$STATE_DIR/rootfs"
DATA_DIR="$STATE_DIR/data"
LOG_DIR="$STATE_DIR/logs"
PID_FILE="$STATE_DIR/qinglong.pid"
LOCK_DIR="$STATE_DIR/.install.lock"
OP_LOCK_DIR="$STATE_DIR/.operation.lock"
CONFIG_FILE="$STATE_DIR/config.env"
DEFAULT_CONFIG="$MODDIR/config.env"

log() {
  echo "[青龙模块] $*"
}

operation_lock_acquire() {
  mkdir -p "$STATE_DIR"
  if mkdir "$OP_LOCK_DIR" 2>/dev/null; then
    echo "$$" >"$OP_LOCK_DIR/pid"
    return 0
  fi
  ol_pid="$(cat "$OP_LOCK_DIR/pid" 2>/dev/null)"
  if [ -z "$ol_pid" ] || ! kill -0 "$ol_pid" 2>/dev/null; then
    rm -rf "$OP_LOCK_DIR"
    mkdir "$OP_LOCK_DIR" 2>/dev/null || return 1
    echo "$$" >"$OP_LOCK_DIR/pid"
    return 0
  fi
  return 1
}

run_locked() {
  if ! operation_lock_acquire; then
    log "已有启动或重启任务正在执行，请稍候"
    return 1
  fi
  trap 'rm -rf "$OP_LOCK_DIR"' EXIT INT TERM
  "$@"
}

cancel_operation_and_stop() {
  cos_pid="$(cat "$OP_LOCK_DIR/pid" 2>/dev/null)"
  if [ -n "$cos_pid" ] && [ "$cos_pid" != "$$" ] && kill -0 "$cos_pid" 2>/dev/null; then
    log "正在取消进行中的启动或重启任务（PID $cos_pid）"
    kill "$cos_pid" 2>/dev/null
    cos_tries=0
    while kill -0 "$cos_pid" 2>/dev/null && [ "$cos_tries" -lt 5 ]; do
      sleep 1
      cos_tries=$((cos_tries + 1))
    done
    kill -9 "$cos_pid" 2>/dev/null || true
  fi
  rm -rf "$OP_LOCK_DIR"
  stop_service
}

config_init() {
  mkdir -p "$STATE_DIR"
  if [ ! -f "$CONFIG_FILE" ]; then
    cp "$DEFAULT_CONFIG" "$CONFIG_FILE"
    chmod 0600 "$CONFIG_FILE"
    return
  fi
  ci_tmp="$CONFIG_FILE.documented.$$"
  : >"$ci_tmp"
  while IFS= read -r ci_line; do
    case "$ci_line" in
      ""|\#*) echo "$ci_line" >>"$ci_tmp" ;;
      *)
        ci_key="${ci_line%%=*}"
        ci_default="${ci_line#*=}"
        ci_value="$(sed -n "s/^${ci_key}=//p" "$CONFIG_FILE" | tail -n 1)"
        printf '%s=%s\n' "$ci_key" "${ci_value:-$ci_default}" >>"$ci_tmp"
        ;;
    esac
  done <"$DEFAULT_CONFIG"
  chmod 0600 "$ci_tmp"
  mv "$ci_tmp" "$CONFIG_FILE"
}

config_get() {
  config_init
  cg_key="$1"
  is_config_key "$cg_key" || return 1
  sed -n "s/^${cg_key}=//p" "$CONFIG_FILE" | tail -n 1
}

is_config_key() {
  case "$1" in
    QL_PORT|TZ|DNS|BOOT_DELAY|AUTO_START) return 0 ;;
    *) return 1 ;;
  esac
}

validate_config() {
  vc_key="$1"
  vc_value="$2"
  case "$vc_key" in
    QL_PORT)
      case "$vc_value" in *[!0-9]*|"") return 1 ;; esac
      [ "$vc_value" -ge 1 ] && [ "$vc_value" -le 65535 ]
      ;;
    BOOT_DELAY)
      case "$vc_value" in *[!0-9]*|"") return 1 ;; esac
      [ "$vc_value" -ge 0 ] && [ "$vc_value" -le 600 ]
      ;;
    AUTO_START)
      [ "$vc_value" = "0" ] || [ "$vc_value" = "1" ]
      ;;
    TZ)
      case "$vc_value" in *[!A-Za-z0-9_+./-]*|"") return 1 ;; esac
      ;;
    DNS)
      case "$vc_value" in *[!A-Fa-f0-9:.,]*|"") return 1 ;; esac
      ;;
    *) return 1 ;;
  esac
}

config_set() {
  cs_key="$1"
  cs_value="$2"
  if ! validate_config "$cs_key" "$cs_value"; then
    log "$cs_key 的配置值无效"
    return 1
  fi
  config_init
  cs_tmp="$CONFIG_FILE.tmp.$$"
  grep -v "^${cs_key}=" "$CONFIG_FILE" >"$cs_tmp" || true
  printf '%s=%s\n' "$cs_key" "$cs_value" >>"$cs_tmp"
  chmod 0600 "$cs_tmp"
  mv "$cs_tmp" "$CONFIG_FILE"
  log "$cs_key 已更新"
}

config_list() {
  config_init
  cat "$CONFIG_FILE"
}

load_config() {
  QL_PORT="$(config_get QL_PORT)"
  TZ="$(config_get TZ)"
  DNS="$(config_get DNS)"
  BOOT_DELAY="$(config_get BOOT_DELAY)"
  AUTO_START="$(config_get AUTO_START)"
  export QL_PORT TZ DNS BOOT_DELAY AUTO_START
}

sha256_file() {
  if command -v sha256sum >/dev/null 2>&1; then
    sha256sum "$1" | awk '{print $1}'
  else
    toybox sha256sum "$1" | awk '{print $1}'
  fi
}

extract_runtime() {
  er_archive="$1"
  er_target="$2"
  if [ -x /data/adb/ksu/bin/busybox ]; then
    /data/adb/ksu/bin/busybox gzip -dc "$er_archive" |
      /data/adb/ksu/bin/busybox tar -xpf - -C "$er_target"
  elif [ -x /data/adb/magisk/busybox ]; then
    /data/adb/magisk/busybox gzip -dc "$er_archive" |
      /data/adb/magisk/busybox tar -xpf - -C "$er_target"
  else
    gzip -dc "$er_archive" | tar -xpf - -C "$er_target"
  fi
}

install_runtime() {
  expected="$(cat "$MODDIR/runtime.sha256" 2>/dev/null)"
  installed="$(cat "$STATE_DIR/runtime.sha256" 2>/dev/null)"
  if [ -x "$ROOTFS/usr/local/bin/qinglong-container-entrypoint" ] &&
    [ -n "$expected" ] && [ "$expected" = "$installed" ]; then
    return 0
  fi

  if ! mkdir "$LOCK_DIR" 2>/dev/null; then
    log "已有运行环境安装任务正在执行"
    return 1
  fi
  trap 'rm -rf "$LOCK_DIR"' EXIT INT TERM

  mkdir -p "$STATE_DIR" "$DATA_DIR" "$LOG_DIR"
  archive="$MODDIR/runtime.tar.gz"
  if [ ! -s "$archive" ] || [ -z "$expected" ]; then
    log "内置运行包缺失或不完整，请重新安装模块"
    return 1
  fi
  actual="$(sha256_file "$archive")"
  if [ "$expected" != "$actual" ]; then
    log "运行包校验失败，请重新安装模块"
    return 1
  fi

  rm -rf "$ROOTFS.new"
  mkdir -p "$ROOTFS.new"
  if ! extract_runtime "$archive" "$ROOTFS.new"; then
    log "运行环境解压失败，请查看 $LOG_DIR/service.log"
    rm -rf "$ROOTFS.new"
    return 1
  fi
  if [ ! -x "$ROOTFS.new/usr/local/bin/qinglong-container-entrypoint" ]; then
    log "运行环境解压不完整"
    rm -rf "$ROOTFS.new"
    return 1
  fi
  rm -rf "$ROOTFS"
  mv "$ROOTFS.new" "$ROOTFS"
  printf '%s\n' "$expected" >"$STATE_DIR/runtime.sha256"
  rm -f "$archive"
  log "运行环境安装完成"
}

is_mounted() {
  grep -q " $1 " /proc/mounts 2>/dev/null
}

bind_mount() {
  source="$1"
  target="$2"
  mkdir -p "$target"
  is_mounted "$target" || mount -o bind "$source" "$target"
}

bind_device() {
  bd_source="$1"
  bd_target="$2"
  mkdir -p "${bd_target%/*}"
  [ -e "$bd_target" ] || : >"$bd_target"
  is_mounted "$bd_target" || mount -o bind "$bd_source" "$bd_target"
}

mount_runtime() {
  mkdir -p "$DATA_DIR" "$ROOTFS/ql/data" "$ROOTFS/proc" "$ROOTFS/sys" "$ROOTFS/dev"
  bind_mount "$DATA_DIR" "$ROOTFS/ql/data"
  bind_mount /proc "$ROOTFS/proc"
  bind_mount /sys "$ROOTFS/sys"
  for device in null zero random urandom; do
    bind_device "/dev/$device" "$ROOTFS/dev/$device"
  done
  load_config
  : >"$ROOTFS/etc/resolv.conf"
  old_ifs="$IFS"
  IFS=,
  for server in $DNS; do
    printf 'nameserver %s\n' "$server" >>"$ROOTFS/etc/resolv.conf"
  done
  IFS="$old_ifs"
}

unmount_runtime() {
  for path in dev/urandom dev/random dev/zero dev/null sys proc ql/data; do
    is_mounted "$ROOTFS/$path" && umount "$ROOTFS/$path" 2>/dev/null
  done
}

process_alive() {
  pa_pid="$1"
  kill -0 "$pa_pid" 2>/dev/null || return 1
  pa_state="$(awk '{print $3}' "/proc/$pa_pid/stat" 2>/dev/null)"
  [ "$pa_state" != "Z" ]
}

process_uses_rootfs() {
  pur_pid="$1"
  pur_root="$(readlink "/proc/$pur_pid/root" 2>/dev/null)"
  [ "$pur_root" = "$ROOTFS" ]
}

stop_chroot_processes() {
  if [ -x "$ROOTFS/usr/local/bin/pm2" ]; then
    chroot "$ROOTFS" /usr/bin/env \
      PATH="/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin" \
      HOME=/root PM2_HOME=/root/.pm2 TMPDIR=/tmp TMP=/tmp TEMP=/tmp \
      /usr/local/bin/pm2 kill >/dev/null 2>&1 || true
  fi

  for pur_dir in /proc/[0-9]*; do
    pur_pid="${pur_dir##*/}"
    [ "$pur_pid" = "$$" ] && continue
    process_uses_rootfs "$pur_pid" && kill "$pur_pid" 2>/dev/null
  done
  sleep 2
  for pur_dir in /proc/[0-9]*; do
    pur_pid="${pur_dir##*/}"
    [ "$pur_pid" = "$$" ] && continue
    process_uses_rootfs "$pur_pid" && kill -9 "$pur_pid" 2>/dev/null
  done
}

is_running() {
  [ -s "$PID_FILE" ] && process_alive "$(cat "$PID_FILE")"
}

start_service() {
  if is_running; then
    log "青龙已在运行（PID $(cat "$PID_FILE")）"
    return 0
  fi
  install_runtime || return 1
  mount_runtime || return 1
  load_config
  mkdir -p "$ROOTFS/tmp"
  chmod 1777 "$ROOTFS/tmp"

  log "正在启动青龙，端口：$QL_PORT"
  (
    export QlPort="$QL_PORT" BACK_PORT="$QL_PORT" TZ
    export HOME=/root PM2_HOME=/root/.pm2
    export TMPDIR=/tmp TMP=/tmp TEMP=/tmp
    chroot "$ROOTFS" /usr/local/bin/qinglong-container-entrypoint
  ) >>"$LOG_DIR/qinglong.log" 2>&1 &
  pid=$!
  echo "$pid" >"$PID_FILE"
  sleep 3
  if ! kill -0 "$pid" 2>/dev/null; then
    log "青龙启动时异常退出，请查看 $LOG_DIR/qinglong.log"
    rm -f "$PID_FILE"
    return 1
  fi
  ready=0
  tries=0
  while [ "$tries" -lt 30 ]; do
    if chroot "$ROOTFS" /usr/bin/curl -fsS --max-time 2 \
      "http://127.0.0.1:$QL_PORT/api/health" >/dev/null 2>&1; then
      ready=1
      break
    fi
    sleep 2
    tries=$((tries + 1))
  done
  if [ "$ready" != "1" ]; then
    log "青龙进程存在，但端口 $QL_PORT 健康检查失败"
    pm2_port="$(
      chroot "$ROOTFS" /usr/bin/env \
        PATH="/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin" \
        HOME=/root PM2_HOME=/root/.pm2 TMPDIR=/tmp TMP=/tmp TEMP=/tmp \
        /usr/local/bin/pm2 env 0 2>/dev/null |
        sed -n 's/^BACK_PORT: */PM2 实际 BACK_PORT=/p' |
        head -n 1
    )"
    log "${pm2_port:-无法从 PM2 读取实际端口}"
    stop_service
    return 1
  fi
  log "青龙启动成功（PID $pid）：http://127.0.0.1:$QL_PORT"
}

stop_service() {
  stop_chroot_processes
  if is_running; then
    pid="$(cat "$PID_FILE")"
    log "正在停止青龙（PID $pid）"
    kill "$pid" 2>/dev/null
    tries=0
    while process_alive "$pid" && [ "$tries" -lt 15 ]; do
      sleep 1
      tries=$((tries + 1))
    done
    kill -9 "$pid" 2>/dev/null || true
  fi
  rm -f "$PID_FILE"
  unmount_runtime
  log "青龙已停止"
}

restart_service() {
  stop_service
  start_service
}

status_service() {
  if is_running; then
    log "运行中（PID $(cat "$PID_FILE")）"
    load_config
    log "面板地址：http://127.0.0.1:$QL_PORT"
  elif [ -d "$ROOTFS" ]; then
    log "运行环境已安装，青龙未启动"
  else
    log "运行环境尚未安装"
  fi
}

show_logs() {
  sl_lines="${1:-100}"
  echo "===== 青龙运行日志 ====="
  tail -n "$sl_lines" "$LOG_DIR/qinglong.log" 2>/dev/null
  echo
  echo "===== 模块后台重启日志 ====="
  tail -n "$sl_lines" "$LOG_DIR/restart.log" 2>/dev/null
  echo
  echo "===== 模块开机启动日志 ====="
  tail -n "$sl_lines" "$LOG_DIR/service.log" 2>/dev/null
}

doctor() {
  config_init
  echo "state_dir=$STATE_DIR"
  echo "config_file=$CONFIG_FILE"
  echo "config_readable=$([ -r "$CONFIG_FILE" ] && echo yes || echo no)"
  echo "runtime_archive=$([ -s "$MODDIR/runtime.tar.gz" ] && echo present || echo absent)"
  echo "rootfs=$([ -x "$ROOTFS/usr/local/bin/qinglong-container-entrypoint" ] && echo installed || echo missing)"
  echo "running=$(is_running && echo yes || echo no)"
}

module_version() {
  sed -n 's/^version=//p' "$MODDIR/module.prop" | head -n 1
}

restart_async() {
  mkdir -p "$LOG_DIR"
  ra_pid="$(cat "$OP_LOCK_DIR/pid" 2>/dev/null)"
  if [ -n "$ra_pid" ] && kill -0 "$ra_pid" 2>/dev/null; then
    log "已有重启任务正在执行，请稍候"
    return 0
  fi
  nohup "$MODDIR/bin/ql" restart </dev/null >>"$LOG_DIR/restart.log" 2>&1 &
  log "已提交后台重启任务"
}

account_value_valid() {
  av_kind="$1"
  av_value="$2"
  case "$av_value" in *'
'*) return 1 ;; esac
  # QingLong's official reset shell command interpolates this value into JSON.
  # Reject the characters that could escape or expand inside that command.
  if printf '%s' "$av_value" | grep -q '[\\"$`]'; then
    return 1
  fi
  av_length="${#av_value}"
  case "$av_kind" in
    username) [ "$av_length" -ge 1 ] && [ "$av_length" -le 64 ] ;;
    password)
      [ "$av_length" -ge 6 ] && [ "$av_length" -le 128 ] &&
        [ "$av_value" != "admin" ]
      ;;
    *) return 1 ;;
  esac
}

account_command() {
  ac_action="$1"
  ac_value="${2:-}"
  case "$ac_action" in
    set-username)
      account_value_valid username "$ac_value" || {
        log "用户名长度必须为 1-64 个字符，且不能包含换行、引号、反斜杠、美元符号或反引号"
        return 1
      }
      ;;
    set-password)
      account_value_valid password "$ac_value" || {
        log "密码需为 6-128 位且不能为 admin；不支持引号、反斜杠、美元符号、反引号或换行"
        return 1
      }
      ;;
    reset-lock|disable-2fa) ;;
    *)
      echo "用法：ql account {set-username 用户名|set-password 密码|reset-lock|disable-2fa}"
      return 2
      ;;
  esac
  if ! is_running; then
    log "请先启动青龙，再修改账号安全设置"
    return 1
  fi
  load_config
  ac_path="/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"
  case "$ac_action" in
    set-username)
      chroot "$ROOTFS" /usr/bin/env PATH="$ac_path" QlPort="$QL_PORT" \
        /ql/shell/update.sh resetname "$ac_value"
      ;;
    set-password)
      chroot "$ROOTFS" /usr/bin/env PATH="$ac_path" QlPort="$QL_PORT" \
        /ql/shell/update.sh resetpwd "$ac_value"
      ;;
    reset-lock)
      chroot "$ROOTFS" /usr/bin/env PATH="$ac_path" QlPort="$QL_PORT" \
        /ql/shell/update.sh resetlet
      ;;
    disable-2fa)
      chroot "$ROOTFS" /usr/bin/env PATH="$ac_path" QlPort="$QL_PORT" \
        /ql/shell/update.sh resettfa
      ;;
  esac
}

case "${1:-}" in
  start) run_locked start_service ;;
  stop) cancel_operation_and_stop ;;
  restart) run_locked restart_service ;;
  restart-async) restart_async ;;
  status) status_service ;;
  install) install_runtime ;;
  logs) show_logs "${2:-100}" ;;
  doctor) doctor ;;
  version) module_version ;;
  account)
    ac_value="${4:-${3:-}}"
    if [ "$ac_value" = "-" ]; then
      ac_value="$(cat)"
    fi
    account_command "${2:-}" "$ac_value"
    ;;
  config)
    case "${2:-}" in
      init) config_init ;;
      get)
        [ -n "${3:-}" ] || exit 2
        config_get "$3"
        ;;
      set)
        [ -n "${3:-}" ] || exit 2
        if [ "${4:-}" = "-" ]; then
          value="$(cat)"
        else
          value="${4:-}"
        fi
        config_set "$3" "$value"
        ;;
      list) config_list ;;
      *) echo "用法：ql config {init|get 键名|set 键名 值|list}"; exit 2 ;;
    esac
    ;;
  shell)
    install_runtime
    mount_runtime
    exec chroot "$ROOTFS" /bin/bash
    ;;
  *)
    echo "用法：ql {install|start|stop|restart|restart-async|status|logs [行数]|doctor|version|shell|config ...|account ...}"
    exit 2
    ;;
esac
